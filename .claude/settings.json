{
  "enabledPlugins": {
    "commit-commands@claude-code-plugins": true,
    "scraps@scraps-claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "scraps-claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "boykush/scraps"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(scraps:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-remote.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
